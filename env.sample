############################
# Frontend
############################

# API backend URL cho React (Vite)
# - Dev local: http://localhost:3001/api
# - Deploy (Vercel/Railway/...): URL backend /api tương ứng
VITE_API_URL=http://localhost:3001/api


############################
# SMTP – gửi email nhắc định kỳ
############################

# Host SMTP
# Ví dụ Gmail: smtp.gmail.com
SMTP_HOST=smtp.gmail.com

# Port SMTP
# Thường là 587 (TLS)
SMTP_PORT=587

# Tài khoản SMTP (email dùng để gửi)
SMTP_USER=your_email@gmail.com

# Mật khẩu ứng dụng / SMTP password
# Với Gmail: dùng App Password, KHÔNG dùng password đăng nhập thường
SMTP_PASS=your_smtp_password_here

# (Tùy chọn) Tên hiển thị trong email
# Ví dụ: "FinTrack <your_email@gmail.com>"
SMTP_FROM=FinTrack <your_email@gmail.com>


